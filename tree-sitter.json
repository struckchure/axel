{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "axel",
      "camelcase": "Axel",
      "title": "Axel",
      "scope": "source.axel",
      "file-types": ["axel"],
      "injection-regex": "^axel$",
      "class-name": "TreeSitterAxel"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Axel is a modern database tool primarily designed for Go, with multi-language support.",
    "authors": [
      {
        "name": "Mohammed Al-Ameen",
        "email": "ameenmohammed2311@gmail.com",
        "url": "https://github.com/struckchure"
      }
    ],
    "links": {
      "repository": "https://github.com/struckchure/axel"
    }
  },
  "bindings": {
    "c": false,
    "go": true,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
